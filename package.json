{
  "name": "balancer",
  "version": "0.1.0",
  "scripts": {
    "create": "graph create balancer-labs/v2-smol --node https://api.thegraph.com/deploy/",
    "create:local": "graph create balancer-labs/v2-smol --node http://localhost:8020",
    "codegen": "npm run generate-manifests subgraph.polygon.yaml && graph codegen --output-dir src/types/",
    "build": "graph build",
    "lint": "eslint --max-warnings 0 . --ext .ts",
    "deploy": "graph deploy balancer-labs/v2-smol --ipfs https://api.thegraph.com/ipfs/ --node https://api.thegraph.com/deploy/",
    "deploy:local": "graph deploy balancer-labs/v2-smol subgraph.yaml --ipfs http://localhost:5001 --node http://127.0.0.1:8020",
    "import-abis": "ts-node ./scripts/update-abis.ts",
    "generate-assets": "ts-node ./scripts/generate-assets",
    "generate-manifests": "ts-node ./scripts/generate-manifests",
    "update-addresses": "ts-node ./scripts/update-addresses-subgraph.ts",
    "fetch-block": "ts-node ./scripts/fetch-latest-block.ts",
    "sync": "npm run import-abis && npm run update-addresses && npm run codegen && npm run build"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.98.0",
    "@graphprotocol/graph-ts": "0.38.2",
    "@types/node": "^16.4.1",
    "@typescript-eslint/eslint-plugin": "^4.1.1",
    "@typescript-eslint/parser": "^4.1.1",
    "assemblyscript": "0.19.10",
    "eslint": "^7.9.0",
    "eslint-plugin-prettier": "^3.1.4",
    "glob": "^7.1.6",
    "handlebars": "^4.7.7",
    "js-yaml": "^4.0.0",
    "prettier": "^2.1.2",
    "ts-node": "^10.1.0",
    "typescript": "^4.0.2"
  }
}
